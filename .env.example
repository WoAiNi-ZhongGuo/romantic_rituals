# Supabase 配置
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# 密码哈希（运行 pnpm hash <你的密码> 获取）
VITE_APP_PASSWORD_HASH=your-password-hash

# GitHub 备份配置（仅 GitHub Actions 使用，本地不需要填）
# SUPABASE_SERVICE_KEY=your-service-role-key
# BACKUP_PAT=your-github-token
# BACKUP_REPO=yourname/lover-photos-backup